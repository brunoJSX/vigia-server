# Postgres connection string used by the Observability persistence layer.
DATABASE_URL=postgres://vigia:vigia@localhost:5432/vigia

# Address the HTTP server binds to.
HTTP_ADDR=:8080

# Public domain used by Caddy for SSL (e.g. 54.12.34.56.sslip.io)
DOMAIN=SEU_IP.sslip.io

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=seu@email.com

# WhatsApp recipient number for notifications (E.164 format, e.g. +5511999999999)
WHATSAPP_RECIPIENT=+5511999999999

# uazapi instance settings
UAZAPI_BASE_URL=https://sua-instancia.uazapi.com
UAZAPI_TOKEN=seu-token-aqui
